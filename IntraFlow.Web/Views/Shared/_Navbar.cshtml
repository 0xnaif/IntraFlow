@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">

        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            IntraFlow
        </a>

        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMenu">

            <ul class="navbar-nav me-auto">

                <li class="nav-item">
                    <a class="nav-link @(currentController == "Requests" && currentAction == "Index" ? "active" : "")"
                       asp-controller="Requests"
                       asp-action="Index">
                        My Requests
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(currentController == "Requests" && currentAction == "Create" ? "active" : "")"
                       asp-controller="Requests"
                       asp-action="Create">
                        Create Request
                    </a>
                </li>
                @if (!User.IsInRole("Employee"))
                { 
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Requests" && currentAction == "Pending" ? "active" : "")"
                       asp-controller="Requests"
                       asp-action="Pending">
                        Pending Reviews
                    </a>
                </li>
                }

            </ul>

            <partial name="_LoginPartial" />

        </div>

    </div>
</nav>