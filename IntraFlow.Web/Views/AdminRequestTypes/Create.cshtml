@model IntraFlow.Web.Models.Admin.CreateRequestTypeViewModel

@{
    ViewData["Title"] = "Create Request Type";
}

<h2>Create Request Type</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="DefaultApproverUserId" class="form-label"></label>
        <select asp-for="DefaultApproverUserId" class="form-select">
            <option value="">-- Select approver --</option>
            @foreach (var approver in Model.Approvers)
            {
                <option value="@approver.Id">
                    @approver.FullName (@approver.Email)
                </option>
            }
        </select>
        <span asp-validation-for="DefaultApproverUserId" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success">Create</button>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}