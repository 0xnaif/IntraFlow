@model IntraFlow.Web.Models.Requests.RequestDetailsPageViewModel
@using IntraFlow.Domain.Requests
@using System.Text.Json
@using System.Security.Claims

@{
    ViewData["Title"] = "Request Details";
    var request = Model.Request;
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<h2 class="mb-3">Request Details</h2>

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert alert-success" role="alert">
        @Model.SuccessMessage
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        @Model.ErrorMessage
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
            <div>
                <h4 class="mb-1">@request.Title</h4>
                <div class="text-muted">
                    Created @request.CreatedAt.ToLocalTime().ToString("g")
                </div>
            </div>

            <span class="badge @GetStatusBadgeClass(request.Status)">
                @request.Status
            </span>
        </div>

        <div class="row g-3">
            <div class="col-12">
                <strong>Description</strong>
                <p class="mb-0 mt-1">@request.Description</p>
            </div>

            <div class="col-md-4">
                <strong>Priority</strong>
                <div class="mt-1">@request.Priority</div>
            </div>

            <div class="col-md-4">
                <strong>Created By</strong>
                <div class="mt-1">@request.CreatedByUserId</div>
            </div>

            <div class="col-md-4">
                <strong>Assigned Approver</strong>
                <div class="mt-1">
                    @(string.IsNullOrWhiteSpace(request.AssignedApproverUserId)
                                        ? "Not assigned"
                                        : request.AssignedApproverUserId)
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mb-4">
    <h4 class="mb-3">Actions</h4>

    @if (Model.HasAnyAvailableAction)
    {
        <div class="d-flex flex-wrap gap-2 mb-3">
            @if (Model.CanSubmit)
            {
                <form asp-action="Submit" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="requestId" value="@request.Id" />
                    <button class="btn btn-success">Submit Request</button>
                </form>
            }

            @if (Model.CanCancel)
            {
                <form asp-action="Cancel" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="requestId" value="@request.Id" />
                    <button class="btn btn-outline-danger">Cancel Request</button>
                </form>
            }

            @if (Model.CanStartReview)
            {
                <form asp-action="StartReview" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="requestId" value="@request.Id" />
                    <button class="btn btn-primary">Start Review</button>
                </form>
            }

            @if (Model.CanApprove)
            {
                <form asp-action="Approve" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="requestId" value="@request.Id" />
                    <button class="btn btn-success">Approve</button>
                </form>
            }
        </div>

        @if (Model.CanReject)
        {
            <div class="card border-danger-subtle">
                <div class="card-body">
                    <h6 class="card-title text-danger mb-3">Reject Request</h6>

                    <form asp-action="Reject" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="requestId" value="@request.Id" />

                        <div class="mb-3">
                            <label for="reason" class="form-label">
                                <strong>Rejection Reason</strong>
                            </label>
                            <textarea id="reason"
                              name="reason"
                              class="form-control"
                              rows="3"
                              maxlength="1000"
                              placeholder="Explain why this request is being rejected."
                              required></textarea>
                        </div>

                        <button type="submit" class="btn btn-danger">Reject</button>
                    </form>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-light border mb-0">
            No workflow actions are currently available for this request.
        </div>
    }
</div>

<hr />

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">Attachments</h4>

        @if (Model.CanUploadAttachment)
        {
            <span class="text-muted small">PDF only, up to 5 MB each</span>
        }
    </div>

    @if (Model.CanUploadAttachment)
    {
        <form asp-action="UploadAttachments" method="post" enctype="multipart/form-data" class="card card-body mb-3">
            @Html.AntiForgeryToken()

            <input type="hidden" name="requestId" value="@request.Id" />

            <div class="mb-3">
                <label for="attachments" class="form-label"><strong>Upload Attachments</strong></label>
                <input id="attachments" name="attachments" type="file" class="form-control" multiple />
            </div>

            <div>
                <button type="submit" class="btn btn-outline-secondary">Upload Attachments</button>
            </div>
        </form>
    }

    @if (Model.Attachments.Any())
    {
        <ul class="list-group">
            @foreach (var file in Model.Attachments)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div>
                        <strong>@file.FileName</strong>
                        <div class="text-muted small mt-1">
                            <span>@(file.FileSizeBytes / 1024) KB</span>
                            <span class="mx-2">•</span>
                            <span>Uploaded @file.UploadedAt.ToLocalTime().ToString("g")</span>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="ViewAttachment"
                           asp-route-attachmentId="@file.Id"
                           target="_blank"
                           class="btn btn-sm btn-outline-primary">
                            View
                        </a>

                        @if (Model.CanDeleteAttachment)
                        {
                            <form asp-action="DeleteAttachment" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="attachmentId" value="@file.Id" />
                                <input type="hidden" name="requestId" value="@request.Id" />

                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    Delete
                                </button>
                            </form>
                        }
                    </div>
                </li>
            }
        </ul>
    }
    else
    {
        <div class="alert alert-light border mb-0">
            No attachments have been uploaded for this request yet.
        </div>
    }
</div>

<hr />

<div class="mb-4">
    <h4 class="mb-3">Comments</h4>

    @if (Model.CanComment)
    {
        <form asp-action="AddComment" method="post" class="card card-body mb-3">
            @Html.AntiForgeryToken()
            <input type="hidden" name="requestId" value="@request.Id" />

            <div class="mb-3">
                <label for="comment" class="form-label"><strong>Add Comment</strong></label>
                <textarea id="comment"
                      name="comment"
                      class="form-control"
                      rows="3"
                      maxlength="2000"
                      placeholder="Write a comment..."
                      required></textarea>
            </div>

            <div>
                <button type="submit" class="btn btn-outline-secondary">Add Comment</button>
            </div>
        </form>
    }

    @if (Model.Comments.Any())
    {
        <div class="mt-3">
            @foreach (var comment in Model.Comments)
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            @if (!string.IsNullOrEmpty(currentUserId) && currentUserId == comment.AuthorUserId)
                                {
                                    <strong>You</strong>
                                }
                                else
                                {
                                    <strong>@comment.AuthorFullName</strong>
                                }
                            
                            <small class="text-muted">
                                @comment.CreatedAt.ToLocalTime().ToString("g")
                            </small>
                        </div>

                        <p class="mb-0">@comment.Body</p>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-light border mb-0">
            No comments yet.
        </div>
    }
</div>

<hr />

<div class="mb-4">
    <h4 class="mb-3">Audit History</h4>

    @if (Model.AuditEntries.Any())
    {
        <div>
            @foreach (var entry in Model.AuditEntries)
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <strong>@entry.ActionType</strong>
                                <div class="text-muted small">
                                    by @entry.PerformedByDisplayName
                                </div>
                            </div>

                            <small class="text-muted">
                                @entry.PerformedAt.ToLocalTime().ToString("g")
                            </small>
                        </div>

                        <p class="mb-2">@entry.Summary</p>

                        @if (!string.IsNullOrWhiteSpace(entry.OldValuesJson)
                                        || !string.IsNullOrWhiteSpace(entry.NewValuesJson)
                                        || !string.IsNullOrWhiteSpace(entry.Notes))
                        {
                            <details>
                                <summary class="text-primary">View technical details</summary>

                                <div class="mt-3">
                                    @if (!string.IsNullOrWhiteSpace(entry.OldValuesJson))
                                    {
                                        <div class="mb-3">
                                            <strong>Old Values</strong>
                                            <pre class="bg-light p-2 rounded small mb-0"><code>@PrettyJson(entry.OldValuesJson)</code></pre>
                                        </div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(entry.NewValuesJson))
                                    {
                                        <div class="mb-3">
                                            <strong>New Values</strong>
                                            <pre class="bg-light p-2 rounded small mb-0"><code>@PrettyJson(entry.NewValuesJson)</code></pre>
                                        </div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(entry.Notes))
                                    {
                                        <div class="mb-0">
                                            <strong>Notes</strong>
                                            <p class="mb-0">@entry.Notes</p>
                                        </div>
                                    }
                                </div>
                            </details>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-light border mb-0">
            No audit history yet.
        </div>
    }
</div>

@functions {
    private static string GetStatusBadgeClass(RequestStatus status)
    {
        return status switch
        {
            RequestStatus.Draft => "bg-secondary",
            RequestStatus.Submitted => "bg-primary",
            RequestStatus.InReview => "bg-warning text-dark",
            RequestStatus.Approved => "bg-success",
            RequestStatus.Rejected => "bg-danger",
            RequestStatus.Cancelled => "bg-dark",
            _ => "bg-secondary"
        };
    }

    private static string PrettyJson(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return string.Empty;

        try
        {
            using var document = JsonDocument.Parse(json);
            return JsonSerializer.Serialize(document.RootElement, new JsonSerializerOptions
            {
                WriteIndented = true
            });
        }
        catch
        {
            return json;
        }
    }
}