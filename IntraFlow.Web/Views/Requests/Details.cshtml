@model IntraFlow.Web.Models.Requests.RequestDetailsPageViewModel
@using IntraFlow.Domain.Requests
@using System.Security.Claims
@using System.Text.Json

@{
    ViewData["Title"] = "Request Details";
    var request = Model.Request;
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var IsAuthorized = request.CreatedByUserId == currentUserId || request.AssignedApproverUserId == currentUserId;
    var canComment =
        (IsAuthorized) && (
        request.Status == RequestStatus.Submitted ||
        request.Status == RequestStatus.InReview);

    var canUploadAttachment = request.CreatedByUserId == currentUserId &&
        (request.Status == RequestStatus.Draft ||
        request.Status == RequestStatus.Submitted ||
        request.Status == RequestStatus.InReview);

    var canDeleteAttachment = request.CreatedByUserId == currentUserId &&
        request.Status == RequestStatus.Draft;
}

<h2>Request Details</h2>

<hr />

<div class="card mb-4">

    <div class="card-body">

        <h4>@request.Title</h4>

        <p class="text-muted">
            Created @request.CreatedAt.ToShortDateString()
        </p>

        <p>
            <strong>Description</strong><br />
            @request.Description
        </p>

        <p>
            <strong>Priority:</strong> @request.Priority
        </p>

        <p>
            <strong>Status:</strong>
            <span class="badge bg-secondary">
                @request.Status
            </span>
        </p>

    </div>
        
</div>

<hr />

<h4>Actions</h4>

@if (request.Status == RequestStatus.Draft)
{
    <form asp-action="Submit" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <input type="hidden" name="requestId" value="@request.Id" />
        <button class="btn btn-success">Submit Request</button>
    </form>

    <form asp-action="Cancel" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <input type="hidden" name="requestId" value="@request.Id" />
        <button class="btn btn-danger">Cancel</button>
    </form>
}

@if (request.Status == RequestStatus.Submitted
    && request.AssignedApproverUserId == User.FindFirstValue(ClaimTypes.NameIdentifier))
{
    <form asp-action="StartReview" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <input type="hidden" name="requestId" value="@request.Id" />
        <button class="btn btn-primary">Start Review</button>
    </form>
}

@if (request.Status == RequestStatus.InReview
    && request.AssignedApproverUserId == User.FindFirstValue(ClaimTypes.NameIdentifier))
{
    <form asp-action="Approve" method="post" class="d-inline me-2">
        @Html.AntiForgeryToken()
        <input type="hidden" name="requestId" value="@request.Id" />
        <button class="btn btn-success">Approve</button>
    </form>

    <form asp-action="Reject" method="post" class="mt-3">
        @Html.AntiForgeryToken()
        <input type="hidden" name="requestId" value="@request.Id" />

        <div class="mb-2">
            <label for="reason" class="form-label"><strong>Rejection Reason</strong></label>
            <textarea name="reason" id="reason" class="form-control" rows="3" required></textarea>
        </div>
        <button type="submit" class="btn btn-danger">Reject</button>
    </form>


}
@if (request.Status == RequestStatus.Approved || request.Status == RequestStatus.Rejected || request.Status == RequestStatus.Cancelled)
{
    <p class="text-muted">
        No Actions.
    </p>
}

<hr />

<h4>Attachments</h4>

@if (IsAuthorized)
{
    @if (canUploadAttachment)
    {
        <form asp-action="UploadAttachments" method="post" enctype="multipart/form-data" class="mt-3">
            @Html.AntiForgeryToken()
            <input type="hidden" name="requestId" value="@request.Id" />

            <div class="mb-3">
                <label for="attachments" class="form-label">Upload Attachments</label>
                <input id="attachments" name="attachments" type="file" class="form-control" multiple />
            </div>

            <button type="submit" class="btn btn-secondary">Upload Attachments</button>
        </form>
    }

    @if (Model.Attachments.Any())
    {
        <ul class="list-group mt-3">
            @foreach (var file in Model.Attachments)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <strong>@file.FileName</strong>
                        <small class="text-muted ms-2">
                            (@(file.FileSizeBytes / 1024) KB)
                        </small>
                        <small class="text-muted ms-2">
                            Uploaded @file.UploadedAt.ToLocalTime().ToString("g")
                        </small>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="ViewAttachment"
                            asp-route-attachmentId="@file.Id"
                            target="_blank"
                            class="btn btn-sm btn-outline-primary">
                            View
                        </a>
                        @if (canDeleteAttachment)
                        {
                            <form asp-action="DeleteAttachment" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="attachmentId" value="@file.Id" />
                                <input type="hidden" name="requestId" value="@request.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    Delete
                                </button>
                            </form>
                        }
                    </div>
                </li>
            }
        </ul>
    }
    else
    {
        <p class="text-muted">
            No attachments yet.
        </p>
    }
}

<hr />

<h4>Comments</h4>

@if (IsAuthorized)
{
    @if (canComment)
    {
        <form asp-action="AddComment" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="requestId" value="@request.Id" />

            <div class="mb-3">
                <label for="comment" class="form-label">Add Comment</label>
                <textarea id="comment" name="comment" class="form-control" placeholder="Write a comment..." rows="3" required></textarea>
            </div>

            <button type="submit" class="btn btn-secondary">Add Comment</button>
        </form>
    }

    @if (Model.Comments.Any())
    {
        <div class="mt-3">
            @foreach (var comment in Model.Comments)
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            @if (currentUserId == comment.AuthorUserId)
                            {
                                <strong>You</strong>
                            }
                            else {
                                <strong>@comment.AuthorFullName</strong>
                            }
                            
                            <small class="text-muted">
                                @comment.CreatedAt.ToLocalTime().ToString("g")
                            </small>
                        </div>

                        <p class="mb-0">@comment.Body</p>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">
            No comments yet.
        </p>
    }
}


<hr />

<h4>Audit History</h4>

@if (Model.AuditEntries.Any())
{
    <div class="mt-3">
        @foreach (var entry in Model.AuditEntries)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <strong>@entry.ActionType</strong>
                            <div class="text-muted small">
                                by @entry.PerformedByDisplayName
                            </div>
                        </div>

                        <small class="text-muted">
                            @entry.PerformedAt.ToLocalTime().ToString("g")
                        </small>
                    </div>

                    <p class="mb-2">@entry.Summary</p>

                    @if (!string.IsNullOrWhiteSpace(entry.OldValuesJson)
                                || !string.IsNullOrWhiteSpace(entry.NewValuesJson)
                                || !string.IsNullOrWhiteSpace(entry.Notes))
                    {
                        <details>
                            <summary class="text-primary">View technical details</summary>

                            <div class="mt-3">
                                @if (!string.IsNullOrWhiteSpace(entry.OldValuesJson))
                                {
                                    <div class="mb-3">
                                        <strong>Old Values</strong>
                                        <pre class="bg-light p-2 rounded small mb-0"><code>@PrettyJson(entry.OldValuesJson)</code></pre>
                                    </div>
                                }

                                @if (!string.IsNullOrWhiteSpace(entry.NewValuesJson))
                                {
                                    <div class="mb-3">
                                        <strong>New Values</strong>
                                        <pre class="bg-light p-2 rounded small mb-0"><code>@PrettyJson(entry.NewValuesJson)</code></pre>
                                    </div>
                                }

                                @if (!string.IsNullOrWhiteSpace(entry.Notes))
                                {
                                    <div class="mb-0">
                                        <strong>Notes</strong>
                                        <p class="mb-0">@entry.Notes</p>
                                    </div>
                                }
                            </div>
                        </details>
                    }
                </div>
            </div>
        }
    </div>
}
else
{
    <p class="text-muted">
        No audit history yet.
    </p>
}

@functions {
    private static string PrettyJson(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return string.Empty;

        try
        {
            using var document = JsonDocument.Parse(json);
            return JsonSerializer.Serialize(document.RootElement, new JsonSerializerOptions
            {
                WriteIndented = true
            });
        }
        catch
        {
            return json;
        }
    }
}