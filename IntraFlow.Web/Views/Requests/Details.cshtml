@model IntraFlow.Application.Requests.DTOs.RequestDetailsDto
@using IntraFlow.Domain.Requests
@using System.Security.Claims

@{
    ViewData["Title"] = "Request Details";
}

<h2>Request Details</h2>

<hr />

<div class="card mb-4">

    <div class="card-body">

        <h4>@Model.Title</h4>

        <p class="text-muted">
            Created @Model.CreatedAt.ToShortDateString()
        </p>

        <p>
            <strong>Description</strong><br />
            @Model.Description
        </p>

        <p>
            <strong>Priority:</strong> @Model.Priority
        </p>

        <p>
            <strong>Status:</strong>
            <span class="badge bg-secondary">
                @Model.Status
            </span>
        </p>

    </div>
        
</div>

<hr />

<h4>Actions</h4>

@if (Model.Status == RequestStatus.Draft)
{
    <form asp-action="Submit" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <input type="hidden" name="requestId" value="@Model.Id" />
        <button class="btn btn-success">Submit Request</button>
    </form>

    <form asp-action="Cancel" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <input type="hidden" name="requestId" value="@Model.Id" />
        <button class="btn btn-danger">Cancel</button>
    </form>
}

@if (Model.Status == RequestStatus.Submitted
    && Model.AssignedApproverUserId == User.FindFirstValue(ClaimTypes.NameIdentifier))
{
    <form asp-action="StartReview" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <input type="hidden" name="requestId" value="@Model.Id" />
        <button class="btn btn-primary">Start Review</button>
    </form>
}

@if (Model.Status == RequestStatus.InReview
    && Model.AssignedApproverUserId == User.FindFirstValue(ClaimTypes.NameIdentifier))
{
    <form asp-action="Approve" method="post" class="d-inline me-2">
        @Html.AntiForgeryToken()
        <input type="hidden" name="requestId" value="@Model.Id" />
        <button class="btn btn-success">Approve</button>
    </form>

    <form asp-action="Reject" method="post" class="mt-3">
        @Html.AntiForgeryToken()
        <input type="hidden" name="requestId" value="@Model.Id" />

        <div class="mb-2">
            <label for="reason" class="form-label"><strong>Rejection Reason</strong></label>
            <textarea name="reason" id="reason" class="form-control" rows="3" required></textarea>
        </div>
        <button type="submit" class="btn btn-danger">Reject</button>
    </form>


}
@if (Model.Status == RequestStatus.Approved || Model.Status == RequestStatus.Rejected || Model.Status == RequestStatus.Cancelled)
{
    <p class="text-muted">
        No Actions.
    </p>
}

<hr />

<h4>Attachments</h4>

<p class="text-muted">
    No attachments yet.
</p>

<hr />

<h4>Comments</h4>

<p class="text-muted">
    No comments yet.
</p>

@if (Model.Status == RequestStatus.Submitted || Model.Status == RequestStatus.InReview)
{
    <h4 class="mt-4">Add Comment</h4>

    <form asp-action="AddComment" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" name="requestId" value="@Model.Id" />

        <div class="mb-2">
            <textarea name="comment" class="form-control" rows="3" placeholder="Write a comment..." required></textarea>
        </div>

        <button type="submit" class="btn btn-secondary">Add Comment</button>
    </form>
}